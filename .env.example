# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git - it holds secrets.

# ---- Bitrix24 ----
# Your inbound webhook URL, created inside Bitrix24 under
# CRM > Settings > Developer resources > Other > Inbound webhook.
# Format: https://<portal>.bitrix24.com/rest/<user id>/<token>/
# Keep the trailing slash. See README.md for exactly which scopes to tick.
BITRIX24_WEBHOOK_URL=

# ---- This server's own identity ----
# The public HTTPS URL this server will be reachable at once deployed
# (no trailing slash). Used as the OAuth issuer/resource URL, so Claude
# can find the /authorize, /token and /mcp endpoints.
# Example: https://mcp.novelsolar.com  or  https://novelsolar.com/bitrix-mcp
MCP_SERVER_URL=

# A password only you know. When Claude's OAuth flow opens a browser tab
# to log in, you'll be asked to type this once. Make it long and random -
# it is the only thing standing between the internet and your Bitrix24 data.
MCP_LOGIN_PASSPHRASE=

# ---- Optional ----
# Port the server listens on. Railway sets this automatically. On cPanel/
# Passenger hosting, cPanel sets this for you too - you normally don't need
# to set it yourself.
PORT=3000
